# =============================================
# AEROMAXRRTEC INVOICE - Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# The .env file is gitignored and will NOT be committed.

# ---- OPTION A: Render PostgreSQL (cloud, external) ----
# Get this from: render.com > your DB > Connect tab > External Database URL
# DATABASE_URL=postgresql://username:password@dpg-xxxxxxxx-a.oregon-postgres.render.com:5432/dbname

# ---- OPTION B: Local pgAdmin / PostgreSQL ----
# Default local PostgreSQL connection
# DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/aeromaxinvoice

# ---- ACTIVE CONNECTION (uncomment one above and paste here) ----
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/aeromaxinvoice

# JWT Secret (can be any random string locally)
JWT_SECRET=aeromaxrr-local-dev-secret-2026

# Environment
NODE_ENV=development

# Port (optional, defaults to 9999)
# PORT=9999
